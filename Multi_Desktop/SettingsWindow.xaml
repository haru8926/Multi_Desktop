<Window x:Class="Multi_Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定 — Multi Desktop"
        Height="700" Width="520"
        MinHeight="400"
        MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1a1a2e">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8899bb"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PathTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#dde0ff"/>
            <Setter Property="Background" Value="#0f0f23"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#5599ff"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Content" Value="..."/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#aabbdd"/>
            <Setter Property="Background" Value="#2a2a4a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- モダンToggleスイッチスタイル -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="SwitchTrack"
                                    Width="44" Height="24"
                                    CornerRadius="12"
                                    Background="#333355"
                                    HorizontalAlignment="Left"/>
                            <Border x:Name="SwitchThumb"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="#8899bb"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#00b4ff"/>
                                <Setter TargetName="SwitchThumb" Property="Background" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="22" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                           To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- スライダースタイル -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <!-- トラック背景 -->
                            <Border Height="4" CornerRadius="2"
                                    Background="#333355"
                                    VerticalAlignment="Center"/>
                            <!-- Track -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#0077dd" Offset="0"/>
                                                            <GradientStop Color="#00b4ff" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White" Width="16" Height="16">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                                                          Color="Black" Opacity="0.3"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ヘッダー -->
            <TextBlock Grid.Row="0"
                       Text="⚙ 設定"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#e0e0ff"
                       Margin="0,0,0,20"/>

            <!-- Main モード設定 -->
            <Border Grid.Row="1" Background="#16213e" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔵 Main モード" FontSize="15" FontWeight="Bold" Foreground="#00b4ff" Margin="0,0,0,12"/>

                    <TextBlock Text="データフォルダ" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}" Click="BrowseMainFolder_Click"/>
                        <TextBox x:Name="MainFolderTextBox" Style="{StaticResource PathTextBox}"/>
                    </DockPanel>

                    <TextBlock Text="壁紙画像" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}" Click="BrowseMainWallpaper_Click"/>
                        <TextBox x:Name="MainWallpaperTextBox" Style="{StaticResource PathTextBox}"/>
                    </DockPanel>

                    <!-- タスクバー設定 -->
                    <Border Background="#0d1a33" CornerRadius="10" Padding="14" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="🖥 タスクバー設定" FontSize="13" FontWeight="Bold" Foreground="#77aadd" Margin="0,0,0,10"/>

                            <!-- スタイル選択 -->
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="MacOS Dock モード" Style="{StaticResource FieldLabel}"
                                          DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <CheckBox x:Name="MainDockToggle"
                                         Style="{StaticResource ToggleSwitch}"
                                         HorizontalAlignment="Right"
                                         Checked="MainDockToggle_Changed"
                                         Unchecked="MainDockToggle_Changed"/>
                            </DockPanel>

                            <!-- Dock詳細設定 (MacOSモード時のみ表示) -->
                            <StackPanel x:Name="MainDockSettingsPanel" Visibility="Collapsed">
                                <Border Height="1" Background="#1a2a44" Margin="0,2,0,10"/>

                                <!-- アイコンサイズ -->
                                <TextBlock Text="アイコンサイズ" Style="{StaticResource FieldLabel}"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock x:Name="MainIconSizeLabel" Text="56px"
                                              DockPanel.Dock="Right" Foreground="#6688aa"
                                              FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Slider x:Name="MainIconSizeSlider"
                                           Style="{StaticResource ModernSlider}"
                                           Minimum="36" Maximum="80" Value="56"
                                           TickFrequency="4" IsSnapToTickEnabled="True"
                                           ValueChanged="MainIconSizeSlider_Changed"/>
                                </DockPanel>

                                <!-- 拡大率 -->
                                <TextBlock Text="ホバー拡大率" Style="{StaticResource FieldLabel}"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock x:Name="MainMagLabel" Text="1.8x"
                                              DockPanel.Dock="Right" Foreground="#6688aa"
                                              FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Slider x:Name="MainMagSlider"
                                           Style="{StaticResource ModernSlider}"
                                           Minimum="10" Maximum="25" Value="18"
                                           TickFrequency="1" IsSnapToTickEnabled="True"
                                           ValueChanged="MainMagSlider_Changed"/>
                                </DockPanel>


                                <!-- ピン留めアプリ管理 -->
                                <Border Height="1" Background="#1a2a44" Margin="0,8,0,10"/>
                                <TextBlock Text="ピン留めアプリ" Style="{StaticResource FieldLabel}"/>
                                <ListBox x:Name="MainPinnedAppsList"
                                        Background="#0a1020"
                                        Foreground="#aabbdd"
                                        BorderBrush="#222244"
                                        BorderThickness="1"
                                        MaxHeight="100"
                                        FontSize="11"
                                        Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="＋ 追加"
                                           Background="#1a3366"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="AddMainPinnedApp_Click"
                                           Margin="0,0,6,0"/>
                                    <Button Content="＋ プロセスから追加"
                                           Background="#2c3e50"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="AddMainPinnedAppFromProcess_Click"
                                           Margin="0,0,6,0"/>
                                    <Button Content="− 削除"
                                           Background="#3a2233"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="RemoveMainPinnedApp_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Sub モード設定 -->
            <Border Grid.Row="2" Background="#1e1638" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🟠 Sub モード" FontSize="15" FontWeight="Bold" Foreground="#c878ff" Margin="0,0,0,12"/>

                    <TextBlock Text="データフォルダ" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}" Click="BrowseSubFolder_Click"/>
                        <TextBox x:Name="SubFolderTextBox" Style="{StaticResource PathTextBox}"/>
                    </DockPanel>

                    <TextBlock Text="壁紙画像" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}" Click="BrowseSubWallpaper_Click"/>
                        <TextBox x:Name="SubWallpaperTextBox" Style="{StaticResource PathTextBox}"/>
                    </DockPanel>

                    <!-- タスクバー設定 -->
                    <Border Background="#150d28" CornerRadius="10" Padding="14" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="🖥 タスクバー設定" FontSize="13" FontWeight="Bold" Foreground="#aa77dd" Margin="0,0,0,10"/>

                            <!-- スタイル選択 -->
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="MacOS Dock モード" Style="{StaticResource FieldLabel}"
                                          DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <CheckBox x:Name="SubDockToggle"
                                         Style="{StaticResource ToggleSwitch}"
                                         HorizontalAlignment="Right"
                                         Checked="SubDockToggle_Changed"
                                         Unchecked="SubDockToggle_Changed"/>
                            </DockPanel>

                            <!-- Dock詳細設定 (MacOSモード時のみ表示) -->
                            <StackPanel x:Name="SubDockSettingsPanel" Visibility="Collapsed">
                                <Border Height="1" Background="#2a1a44" Margin="0,2,0,10"/>

                                <!-- アイコンサイズ -->
                                <TextBlock Text="アイコンサイズ" Style="{StaticResource FieldLabel}"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock x:Name="SubIconSizeLabel" Text="56px"
                                              DockPanel.Dock="Right" Foreground="#8866aa"
                                              FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Slider x:Name="SubIconSizeSlider"
                                           Style="{StaticResource ModernSlider}"
                                           Minimum="36" Maximum="80" Value="56"
                                           TickFrequency="4" IsSnapToTickEnabled="True"
                                           ValueChanged="SubIconSizeSlider_Changed"/>
                                </DockPanel>

                                <!-- 拡大率 -->
                                <TextBlock Text="ホバー拡大率" Style="{StaticResource FieldLabel}"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock x:Name="SubMagLabel" Text="1.8x"
                                              DockPanel.Dock="Right" Foreground="#8866aa"
                                              FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Slider x:Name="SubMagSlider"
                                           Style="{StaticResource ModernSlider}"
                                           Minimum="10" Maximum="25" Value="18"
                                           TickFrequency="1" IsSnapToTickEnabled="True"
                                           ValueChanged="SubMagSlider_Changed"/>
                                </DockPanel>



                                <!-- ピン留めアプリ管理 -->
                                <Border Height="1" Background="#2a1a44" Margin="0,8,0,10"/>
                                <TextBlock Text="ピン留めアプリ" Style="{StaticResource FieldLabel}"/>
                                <ListBox x:Name="SubPinnedAppsList"
                                        Background="#0a0818"
                                        Foreground="#aabbdd"
                                        BorderBrush="#332244"
                                        BorderThickness="1"
                                        MaxHeight="100"
                                        FontSize="11"
                                        Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="＋ 追加"
                                           Background="#3a1a66"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="AddSubPinnedApp_Click"
                                           Margin="0,0,6,0"/>
                                    <Button Content="＋ プロセスから追加"
                                           Background="#2c3e50"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="AddSubPinnedAppFromProcess_Click"
                                           Margin="0,0,6,0"/>
                                    <Button Content="− 削除"
                                           Background="#3a2233"
                                           Style="{StaticResource ActionButton}"
                                           Padding="10,5"
                                           FontSize="11"
                                           Click="RemoveSubPinnedApp_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- その他設定 -->
            <Border Grid.Row="3" Background="#16213e" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⚙ その他設定" FontSize="15" FontWeight="Bold" Foreground="#8899bb" Margin="0,0,0,12"/>
                    
                    <DockPanel>
                        <TextBlock Text="Windows 起動時に自動起動する" Style="{StaticResource FieldLabel}"
                                  DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <CheckBox x:Name="StartupToggle"
                                 Style="{StaticResource ToggleSwitch}"
                                 HorizontalAlignment="Right"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 🎵 ミュージックサービス設定 -->
            <Border Grid.Row="4" Background="#1a1638" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🎵 ミュージックサービス" FontSize="15" FontWeight="Bold" Foreground="#c878ff" Margin="0,0,0,12"/>
                    <TextBlock Text="有効にしたサービスをコントロールセンターで利用できます"
                               FontSize="11" Foreground="#6666aa" Margin="0,0,0,14"/>

                    <!-- YouTube -->
                    <Border Background="#150d28" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▶" FontSize="14" Foreground="#FF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="YouTube" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="YouTubeLoginBtn" Content="ログイン"
                                        Background="#2a1a4a" Foreground="#aabbdd"
                                        FontSize="10" Padding="10,4" Cursor="Hand"
                                        BorderThickness="0" Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="YouTubeLogin_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <CheckBox x:Name="YouTubeToggle"
                                         Style="{StaticResource ToggleSwitch}"
                                         Checked="MusicToggle_Changed"
                                         Unchecked="MusicToggle_Changed"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Amazon Music -->
                    <Border Background="#150d28" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="♪" FontSize="14" Foreground="#25D1DA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Amazon Music" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="AmazonLoginBtn" Content="ログイン"
                                        Background="#2a1a4a" Foreground="#aabbdd"
                                        FontSize="10" Padding="10,4" Cursor="Hand"
                                        BorderThickness="0" Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="AmazonLogin_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <CheckBox x:Name="AmazonMusicToggle"
                                         Style="{StaticResource ToggleSwitch}"
                                         Checked="MusicToggle_Changed"
                                         Unchecked="MusicToggle_Changed"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Spotify -->
                    <Border Background="#150d28" CornerRadius="8" Padding="12,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="●" FontSize="14" Foreground="#1DB954" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Spotify" FontSize="13" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="SpotifyLoginBtn" Content="ログイン"
                                        Background="#2a1a4a" Foreground="#aabbdd"
                                        FontSize="10" Padding="10,4" Cursor="Hand"
                                        BorderThickness="0" Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="SpotifyLogin_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <CheckBox x:Name="SpotifyToggle"
                                         Style="{StaticResource ToggleSwitch}"
                                         Checked="MusicToggle_Changed"
                                         Unchecked="MusicToggle_Changed"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 🤖 AI アシスタント設定 -->
            <Border Grid.Row="5" Background="#161e38" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="✨ &amp; 🤖 AI アシスタント機能" FontSize="15" FontWeight="Bold" Foreground="#60BFFF" Margin="0,0,0,12"/>

                    <!-- Quick AI の設定 -->
                    <TextBlock Text="✨ Quick AI (Web)" FontSize="13" FontWeight="SemiBold" Foreground="#aaddff" Margin="0,0,0,8"/>
                    <TextBlock Text="メニューバーの ✨ アイコンから直接Web上のAIサービスを開きます"
                               FontSize="11" Foreground="#6688aa" Margin="0,0,0,6"/>
                    <TextBlock Text="使用するサービス" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="QuickAiServiceComboBox" Margin="0,0,0,20" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="ChatGPT"/>
                        <ComboBoxItem Content="Gemini"/>
                        <ComboBoxItem Content="Claude"/>
                    </ComboBox>

                    <!-- AI 操作の設定 -->
                    <TextBlock Text="🤖 AI 操作 (アシスタント)" FontSize="13" FontWeight="SemiBold" Foreground="#aaddff" Margin="0,0,0,8"/>
                    <TextBlock Text="Gemini API キーを入力すると、メニューバーの 🤖 アイコンからAIにPCの操作を手伝ってもらえます"
                               FontSize="11" Foreground="#6688aa" Margin="0,0,0,8"/>

                    <TextBlock Text="Gemini API キー" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="GeminiApiKeyBox"
                                 FontSize="12"
                                 Foreground="#dde0ff"
                                 Background="#0f0f23"
                                 BorderBrush="#333355"
                                 BorderThickness="1"
                                 Padding="8,6"
                                 PasswordChar="●"/>
                    <TextBlock Text="Google AI Studio で取得した API キーを入力してください"
                               FontSize="10" Foreground="#556688" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 保存/キャンセルボタン -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="キャンセル"
                        Background="#333355"
                        Style="{StaticResource ActionButton}"
                        Click="CancelButton_Click"
                        Margin="0,0,10,0"/>
                <Button Content="✓ 保存"
                        Background="#0f3460"
                        Style="{StaticResource ActionButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
