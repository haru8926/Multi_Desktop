<Window x:Class="Multi_Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi Desktop Switcher"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Window.Resources>
        <!-- ボタン共通スタイル -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinHeight" Value="56"/>
            <Setter Property="Padding" Value="24,18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="🖥 Multi Desktop"
                   FontSize="28" FontWeight="Bold"
                   Foreground="#e0e0ff"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="デスクトップ環境切り替え"
                   FontSize="13"
                   Foreground="#8888aa"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        <!-- モードインジケーター -->
        <Border Grid.Row="2"
                x:Name="ModeIndicatorBorder"
                Background="#16213e"
                CornerRadius="16"
                Padding="24,20"
                Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="現在のモード"
                           FontSize="12"
                           Foreground="#7777aa"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="ModeText"
                           Text="---"
                           FontSize="36" FontWeight="Bold"
                           Foreground="#00d4ff"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="ModeDescription"
                           Text=""
                           FontSize="11"
                           Foreground="#6677aa"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 切り替えボタン -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center" Margin="0,0,0,16">
            <Button x:Name="SwitchToMainButton"
                    Content="🔵  Main に切り替え"
                    Background="#0f3460"
                    Style="{StaticResource ModernButton}"
                    Click="SwitchToMainButton_Click"
                    Margin="0,0,0,12"/>

            <Button x:Name="SwitchToSubButton"
                    Content="🟠  Sub に切り替え"
                    Background="#533483"
                    Style="{StaticResource ModernButton}"
                    Click="SwitchToSubButton_Click"/>
        </StackPanel>

        <!-- 設定・終了ボタンエリア -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 設定ボタン -->
            <Button Grid.Column="0"
                    x:Name="SettingsButton"
                    Content="⚙  設定"
                    Background="#2a2a4a"
                    Style="{StaticResource ModernButton}"
                    Click="SettingsButton_Click"/>

            <!-- 終了ボタン -->
            <Button Grid.Column="2"
                    x:Name="ExitButton"
                    Content="❌  終了"
                    Background="#5a1a1a"
                    Style="{StaticResource ModernButton}"
                    Click="ExitButton_Click"/>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="5" Background="#0f0f23" CornerRadius="8" Padding="12,8">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="準備完了"
                           FontSize="11"
                           Foreground="#5599ff"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="ホットキー: Ctrl + Shift + S"
                           FontSize="10"
                           Foreground="#444466"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
