<Window x:Class="Multi_Desktop.ProcessSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロセスから追加"
        Height="450" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="現在実行中のアプリ" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
        
        <ListBox x:Name="ProcessList" Grid.Row="1" Background="#0f0f23" Foreground="White" BorderBrush="#333355" BorderThickness="1" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="250"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="キャンセル" Width="80" Height="30" Margin="0,0,8,0" Background="#333355" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="追加" Width="80" Height="30" Background="#0f3460" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>
