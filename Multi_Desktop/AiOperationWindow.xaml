<Window x:Class="Multi_Desktop.AiOperationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="360" Height="520">

    <Window.RenderTransform>
        <TranslateTransform Y="0"/>
    </Window.RenderTransform>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="WindowBorder" CornerRadius="12" Padding="0"
            BorderBrush="#40ffffff" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#f5101018" Offset="0"/>
                <GradientStop Color="#dd0B0B12" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Color="#000000" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Border Grid.Row="0" Padding="12,8,8,6" Background="#18ffffff" 
                    CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://siteoforigin:,,,/Assets/modern_ai_logo.png" 
                               Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock Text="AI アシスタント" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#EAEAEA" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- 最小化（バックグラウンド） -->
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#18ffffff"
                                Margin="0,0,3,0"
                                MouseLeftButtonUp="MinimizePanel_Click"
                                ToolTip="最小化（バックグラウンド待機）">
                            <TextBlock Text="&#xE949;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#88ffffff" VerticalAlignment="Center"/>
                        </Border>
                        <!-- 閉じる（履歴クリア） -->
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#18ffffff"
                                MouseLeftButtonUp="ClosePanel_Click"
                                ToolTip="閉じる（会話履歴をクリア）">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#88ffffff" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <Border/>
                </DockPanel>
            </Border>

            <!-- チャットエリア -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0">
                <StackPanel x:Name="ChatPanel" Margin="10,8,10,8">
                    <!-- 初期メッセージはコードビハインドから動的に追加する -->
                </StackPanel>
            </ScrollViewer>

            <!-- 操作承認バナー -->
            <Border x:Name="ApprovalBanner" Grid.Row="2" Visibility="Collapsed"
                    Background="#33ff8800" CornerRadius="8" Padding="10,8" Margin="10,0,10,6">
                <StackPanel>
                    <TextBlock Text="⚠ AIが以下の操作を要求しています:" FontSize="11"
                               FontWeight="SemiBold" Foreground="#FFCC44" Margin="0,0,0,4"/>
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ApprovalDetails" Text="" FontSize="10.5"
                                   Foreground="#ddddff" TextWrapping="Wrap"/>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Border CornerRadius="6" Padding="12,5" Cursor="Hand"
                                Background="#33ff4444" Margin="0,0,6,0"
                                MouseLeftButtonUp="RejectAction_Click">
                            <TextBlock Text="拒否" FontSize="11" Foreground="#ffaaaa"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <Border CornerRadius="6" Padding="12,5" Cursor="Hand"
                                Background="#3344ff44"
                                MouseLeftButtonUp="ApproveAction_Click">
                            <TextBlock Text="承認" FontSize="11" Foreground="#aaffaa"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 入力エリア -->
            <Border Grid.Row="3" Padding="10,4,10,10">
                <DockPanel>
                    <Border DockPanel.Dock="Right" CornerRadius="8" Padding="10,6"
                            Cursor="Hand" Background="#2255aaff" Margin="6,0,0,0"
                            MouseLeftButtonUp="SendMessage_Click">
                        <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <Border CornerRadius="8" Background="#15ffffff" Padding="2">
                        <TextBox x:Name="MessageInput"
                                 FontSize="12" Foreground="#dde0ff"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="8,6"
                                 CaretBrush="#5599ff"
                                 AcceptsReturn="False"
                                 KeyDown="MessageInput_KeyDown"
                                 VerticalAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
