<Window x:Class="Multi_Desktop.VirtualDesktopOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual Desktop Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        Focusable="True">

    <Grid x:Name="RootGrid" Background="#01000000">
        <ScrollViewer VerticalScrollBarVisibility="Disabled" 
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <ItemsControl x:Name="DesktopItemsControl" Background="Transparent">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Vertical"
                                   x:Name="IconPanel"
                                   Margin="20,20,20,60"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Width="90" Height="100"
                                Margin="5"
                                Background="Transparent"
                                CornerRadius="6"
                                Cursor="Hand"
                                MouseEnter="Item_MouseEnter"
                                MouseLeave="Item_MouseLeave"
                                MouseLeftButtonDown="Item_MouseLeftButtonDown"
                                MouseRightButtonDown="Item_MouseRightButtonDown"
                                ToolTip="{Binding FullPath}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <!-- ファイルアイコン -->
                                <Image Source="{Binding Icon}"
                                       Width="48" Height="48"
                                       HorizontalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <!-- ファイル名 -->
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="White"
                                           FontSize="11"
                                           FontFamily="Yu Gothic UI, Segoe UI"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="80"
                                           MaxHeight="32"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect ShadowDepth="1"
                                                          Color="Black"
                                                          BlurRadius="3"
                                                          Opacity="0.9"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
