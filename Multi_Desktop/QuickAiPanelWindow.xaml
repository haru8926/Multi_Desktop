<Window x:Class="Multi_Desktop.QuickAiPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="400" Height="600">

    <Border x:Name="WindowBorder" CornerRadius="12" Padding="0"
            BorderBrush="#30ffffff" BorderThickness="0.8"
            Background="#1e1e28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Color="#000000" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Border Grid.Row="0" Padding="12,8,8,6" Background="#18ffffff" 
                    CornerRadius="12,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#60BFFF"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="PanelTitle" Text="Quick AI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- ブラウザナビゲーション -->
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#10ffffff"
                                Margin="0,0,8,0" MouseLeftButtonUp="GoBack_Click" ToolTip="戻る">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#aaffffff" VerticalAlignment="Center"/>
                        </Border>
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#10ffffff"
                                Margin="0,0,16,0" MouseLeftButtonUp="Refresh_Click" ToolTip="更新">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#aaffffff" VerticalAlignment="Center"/>
                        </Border>

                        <!-- 最小化（バックグラウンド） -->
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#18ffffff"
                                Margin="0,0,3,0"
                                MouseLeftButtonUp="MinimizePanel_Click"
                                ToolTip="最小化（バックグラウンド待機）">
                            <TextBlock Text="&#xE949;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#88ffffff" VerticalAlignment="Center"/>
                        </Border>
                        <!-- 閉じる -->
                        <Border CornerRadius="6" Padding="6,4" Cursor="Hand" Background="#18ffffff"
                                MouseLeftButtonUp="ClosePanel_Click"
                                ToolTip="閉じる">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#88ffffff" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <Border/>
                </DockPanel>
            </Border>

            <!-- プレースホルダー / ローディング -->
            <StackPanel x:Name="PlaceholderPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#33ffffff" TextAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock x:Name="PlaceholderText" Text="読み込み中..." FontSize="16" Foreground="#88ffffff" TextAlignment="Center"/>
                <TextBlock x:Name="PlaceholderSubText" Text="" FontSize="12" Foreground="#55ffffff" TextAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- WebView2 エリア -->
            <wv2:WebView2 x:Name="AiWebView" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,4"/>
        </Grid>
    </Border>
</Window>
