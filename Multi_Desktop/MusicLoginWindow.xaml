<Window x:Class="Multi_Desktop.MusicLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ログイン — Music Service"
        Height="650" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Border Grid.Row="0" Background="#0f0f23" Padding="16,10">
            <DockPanel>
                <TextBlock x:Name="HeaderText" Text="サービスにログイン"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#e0e0ff" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text=""
                           FontSize="11" Foreground="#6688aa"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Margin="10,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="LoginWebView" Grid.Row="1"/>

        <!-- フッター -->
        <Border Grid.Row="2" Background="#0f0f23" Padding="12,8">
            <DockPanel>
                <TextBlock Text="ログイン完了後、このウィンドウを閉じてください"
                           FontSize="11" Foreground="#6688aa"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseButton" Content="✓ 完了" DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        FontSize="12" FontWeight="SemiBold"
                        Foreground="White" Background="#0f3460"
                        Padding="16,6" Cursor="Hand"
                        BorderThickness="0"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
