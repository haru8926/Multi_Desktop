<Window x:Class="Multi_Desktop.YoutubeTvBackgroundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YouTube TV Background"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="Black"
        ShowInTaskbar="False"
        Topmost="False">

    <!-- 全仮想デスクトップに跨がるキャンバス。各ディスプレイの位置にImageを配置する -->
    <Canvas x:Name="MonitorCanvas" ClipToBounds="True"/>
</Window>
